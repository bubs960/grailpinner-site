  },
  "dependencies": {
    "@clerk/nextjs": "^6.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0"
  },
  "overrides": {
    "@ast-grep/napi": "0.42.1",
    "glob": "10.4.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "typescript": "^5",
    "wrangler": "^4.83.0"
  }
