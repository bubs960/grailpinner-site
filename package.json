{
  "name": "grailpinner-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx --yes cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "next lint",
    "build:cf": "npx --yes cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
